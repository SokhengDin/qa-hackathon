# Gemini API key — used for both the Computer Use loop (gemini-3.5-flash)
# and the Antigravity managed agent (Interactions API, agent=antigravity-preview-05-2026).
GEMINI_API_KEY=

# GitHub Personal Access Token — used by PRAgent (tools/github_pr.py) to commit
# and open PRs against the target app repo, and optionally by the Antigravity
# environment's network allowlist to clone/push to private repos.
GITHUB_TOKEN=

# Target app repo the QA Agent tests and opens PRs against.
GITHUB_REPO=owner/repo

# Postgres connection string for evidence bundles + session state + review decisions.
DATABASE_URL=postgresql://qa_sentinel:qa_sentinel@localhost:5432/qa_sentinel

# otel_endpoint and the target app's base_url are per-run data (see the `runs`
# table), supplied per POST /api/agent/runs call — not global config here.

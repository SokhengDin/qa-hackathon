{
  "name": "cambria-shop",
  "version": "1.0.0",
  "description": "Deliberately-buggy demo shop app for QA Sentinel to test",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build:css": "tailwindcss -i ./public/input.css -o ./public/style.css --minify",
    "watch:css": "tailwindcss -i ./public/input.css -o ./public/style.css --watch"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2"
  }
}
